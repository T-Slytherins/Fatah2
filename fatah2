class C:
    """ANSI colour codes — auto-disabled when stdout is not a tty."""
    _tty = sys.stdout.isatty()

    RESET  = "\033[0m"      if _tty else ""
    BOLD   = "\033[1m"      if _tty else ""
    RED    = "\033[1;31m"   if _tty else ""
    GREEN  = "\033[1;32m"   if _tty else ""
    YELLOW = "\033[1;33m"   if _tty else ""
    CYAN   = "\033[1;36m"   if _tty else ""
    PURPLE = "\033[1;35m"   if _tty else ""
    GRAY   = "\033[0;90m"   if _tty else ""
    WHITE  = "\033[0;37m"   if _tty else ""
    DIM    = "\033[2m"      if _tty else ""

def ok(msg):    print(f"{C.GREEN}  [✓]{C.RESET} {msg}")
def info(msg):  print(f"{C.CYAN}  [*]{C.RESET} {msg}")
def warn(msg):  print(f"{C.YELLOW}  [!]{C.RESET} {msg}")
def err(msg):   print(f"{C.RED}  [✗]{C.RESET} {msg}")
def stage(n, msg): print(f"\n{C.PURPLE}  ══ Stage {n}: {msg}{C.RESET}")
def sep():      print(f"{C.GRAY}  {'─'*54}{C.RESET}")

