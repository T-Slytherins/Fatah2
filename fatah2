def _bootstrap():
    """Auto-install missing Python packages on first run."""
    needed = {
        "click":        "click",
        "httpx":        "httpx",
        "aiohttp":      "aiohttp",
        "dns":          "dnspython",
        "whois":        "python-whois",
        "yaml":         "pyyaml",
        "fastapi":      "fastapi",
        "uvicorn":      "uvicorn[standard]",
        "pydantic":     "pydantic",
    }
    missing = []
    for mod, pkg in needed.items():
        try:
            __import__(mod)
        except ImportError:
            missing.append(pkg)

    if missing:
        warn(f"Auto-installing missing packages: {', '.join(missing)}")
        import subprocess
        cmd = [sys.executable, "-m", "pip", "install", "--quiet",
               "--break-system-packages", *missing]
        result = subprocess.run(cmd, capture_output=True)
        if result.returncode != 0:
            # try without flag
            cmd2 = [sys.executable, "-m", "pip", "install", "--quiet", *missing]
            subprocess.run(cmd2, check=True)
        ok("Packages installed")

